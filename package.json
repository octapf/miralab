{
  "name": "mlab-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "test:coverage": "c8 --check-coverage --lines 60 --functions 60 --branches 50 --statements 60 --reporter=text --reporter=lcov node --import tsx --test tests/*.test.ts",
    "check:i18n": "node ./scripts/check-i18n.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.23.26",
    "next": "16.1.0",
    "next-intl": "^4.6.1",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.1",
    "swiper": "^12.0.3",
    "twilio": "^5.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
